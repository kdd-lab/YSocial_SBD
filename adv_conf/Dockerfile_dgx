# syntax=docker/dockerfile:1
FROM mambaorg/micromamba:latest

USER root

ARG UNAME=giuliorossetti
ARG UID=1056
ARG GID=1056

RUN groupadd -g $GID -o $UNAME && \
    useradd -m -u $UID -g $GID -o -s /bin/bash $UNAME

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    libffi-dev \
    screen \
    libx11-6 \
    libxext6 \
    libxrender1 \
    git \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Create micromamba environment with essential base packages
RUN micromamba create -y -n ysocial python=3.10 pip -c conda-forge \
    && micromamba clean --all --yes

# Set environment variables for the build phase
ENV PATH=/opt/conda/envs/ysocial/bin:$PATH
ARG MAMBA_DOCKERFILE_ACTIVATE=1

# 1. Upgrade pip first (Essential for the new resolver)
RUN /opt/conda/envs/ysocial/bin/python -m pip install --upgrade pip setuptools wheel

# 2. Pre-install "Heavy" AI dependencies
# This anchors the version resolution before the rest of requirements.txt
# We use --extra-index-url to point to the official vLLM pre-compiled wheels
# 1. Anchor the build with the correct Torch + CUDA version for A100s
RUN /opt/conda/envs/ysocial/bin/python -m pip install --no-cache-dir \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# 2. Install vLLM without a hard version pin to allow discovery,
# but include the constraint to satisfy your project needs.
RUN /opt/conda/envs/ysocial/bin/python -m pip install --no-cache-dir \
    vllm>=0.15.0 \
    openai>=1.99.1

# 3. Copy project files and install remaining requirements
COPY . /app
RUN /opt/conda/envs/ysocial/bin/python -m pip install --no-cache-dir -r requirements_fix.txt

# Fix ownership
RUN chown -R $UNAME:$GID /app

USER $UNAME

# Entrypoint
ENTRYPOINT ["/usr/bin/micromamba", "run", "-n", "ysocial"]